<% locals.paginaActual = 'alumnos' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo">Ficha del Alumno</h1>
    <p class="page-sub">Expediente <strong><%= alumno.expediente %></strong></p>
  </div>
  <div class="page-acciones">
    <a href="/alumnos/<%= alumno._id %>/editar" class="btn btn-primario">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Editar
    </a>
    <a href="/alumnos" class="btn btn-secundario">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Volver
    </a>
  </div>
</div>

<div class="detalle-card">
  <div class="detalle-header">
    <div class="detalle-avatar"><%= alumno.nombre[0] %><%= alumno.apellido[0] %></div>
    <div>
      <h2 class="detalle-nombre"><%= alumno.apellido %>, <%= alumno.nombre %></h2>
      <div class="detalle-sub">
        <code><%= alumno.expediente %></code>
        &nbsp;&nbsp;
        <span class="badge badge-<%= alumno.estado==='activo'?'verde':alumno.estado==='retirado'?'rojo':'amarillo' %>"><%= alumno.estado %></span>
      </div>
    </div>
  </div>

  <div class="detalle-grid">
    <div class="detalle-sec">
      <h3>Datos Personales</h3>
      <div class="dato-fila"><span>N. Identidad</span><strong><%= alumno.numIdentidad||'—' %></strong></div>
      <div class="dato-fila"><span>Fecha de Nacimiento</span><strong><%= alumno.fechaNacimiento ? alumno.fechaNacimiento.toLocaleDateString('es-HN') : '—' %></strong></div>
      <div class="dato-fila"><span>Género</span><strong><%= alumno.genero==='M'?'Masculino':alumno.genero==='F'?'Femenino':'—' %></strong></div>
    </div>

    <div class="detalle-sec">
      <h3>Datos Académicos</h3>
      <div class="dato-fila"><span>Grado</span><strong><%= alumno.grado||'—' %></strong></div>
      <div class="dato-fila"><span>Sección</span><strong><%= alumno.seccion ? 'Sección '+alumno.seccion : '—' %></strong></div>
      <div class="dato-fila"><span>Jornada</span><strong style="text-transform:capitalize"><%= alumno.jornada||'—' %></strong></div>
    </div>

    <div class="detalle-sec">
      <h3>Contacto</h3>
      <div class="dato-fila"><span>Correo</span><strong><%= alumno.correo||'—' %></strong></div>
      <div class="dato-fila"><span>Teléfono</span><strong><%= alumno.telefono||'—' %></strong></div>
      <div class="dato-fila"><span>Dirección</span><strong><%= alumno.direccion||'—' %></strong></div>
    </div>

    <div class="detalle-sec">
      <h3>Padre / Tutor Legal</h3>
      <div class="dato-fila"><span>Nombre</span><strong><%= alumno.nombreTutor||'—' %></strong></div>
      <div class="dato-fila"><span>Teléfono</span><strong><%= alumno.telefonoTutor||'—' %></strong></div>
    </div>
  </div>

  <div class="detalle-footer">
    <form action="/alumnos/<%= alumno._id %>/eliminar" method="POST"
          onsubmit="return confirm('Esta acción no se puede deshacer. ¿Eliminar alumno?')">
      <button type="submit" class="btn btn-peligro">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
        Eliminar Alumno
      </button>
    </form>
  </div>
</div>

<%- include('../partials/layout_fin') %>
