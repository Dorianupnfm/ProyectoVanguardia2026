<% locals.paginaActual = 'alumnos' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo"><%= titulo %></h1>
    <p class="page-sub"><%= esEditar ? 'Actualice los datos del alumno' : 'Complete el formulario para registrar un nuevo alumno' %></p>
  </div>
  <a href="/alumnos" class="btn btn-secundario">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Volver
  </a>
</div>

<% var accion = esEditar ? '/alumnos/' + alumno._id : '/alumnos' %>
<form action="<%= accion %>" method="POST" id="formAlumno">

  <div class="form-card">
    <div class="form-seccion-titulo">Identificación del Alumno</div>
    <div class="form-grid">

      <div class="campo">
        <label>Número de Expediente <span class="req">*</span></label>
        <% if (!esEditar) { %>
        <div class="input-group">
          <input type="text" name="expediente" id="inputExpediente"
                 value="<%= alumno.expediente || '' %>"
                 placeholder="EXP-2025-0001" required>
          <button type="button" class="btn-gen" onclick="generarExpediente()">Generar</button>
        </div>
        <span class="campo-hint">Generado automáticamente o personalícelo</span>
        <% } else { %>
        <input type="text" value="<%= alumno.expediente %>" disabled class="input-dis">
        <% } %>
      </div>

      <div class="campo">
        <label>Nombre(s) <span class="req">*</span></label>
        <input type="text" name="nombre" value="<%= alumno.nombre || '' %>" placeholder="Nombres" required>
      </div>

      <div class="campo">
        <label>Apellido(s) <span class="req">*</span></label>
        <input type="text" name="apellido" value="<%= alumno.apellido || '' %>" placeholder="Apellidos" required>
      </div>

      <div class="campo">
        <label>Número de Identidad</label>
        <input type="text" name="numIdentidad" value="<%= alumno.numIdentidad || '' %>" placeholder="0000-0000-00000">
      </div>

      <div class="campo">
        <label>Fecha de Nacimiento</label>
        <input type="date" name="fechaNacimiento"
               value="<%= alumno.fechaNacimiento ? alumno.fechaNacimiento.toISOString().split('T')[0] : '' %>">
      </div>

      <div class="campo">
        <label>Género</label>
        <select name="genero">
          <option value="">Seleccionar...</option>
          <option value="M" <%= alumno.genero==='M'?'selected':'' %>>Masculino</option>
          <option value="F" <%= alumno.genero==='F'?'selected':'' %>>Femenino</option>
        </select>
      </div>

    </div>
  </div>

  <div class="form-card">
    <div class="form-seccion-titulo">Datos Académicos</div>
    <div class="form-grid">

      <div class="campo">
        <label>Grado <span class="req">*</span></label>
        <select name="gradoId" id="selGrado" onchange="cargarSecciones(this.value)">
          <option value="">Seleccionar grado...</option>
          <% grados.forEach(function(g) { %>
          <option value="<%= g._id %>"
            data-nombre="<%= g.nombre %>"
            <%= (alumno.grado && g.nombre === alumno.grado) ? 'selected' : '' %>>
            <%= g.nombre %><% if(g.anioEscolar){%> — <%= g.anioEscolar %><% } %>
          </option>
          <% }) %>
        </select>
        <% if (!grados.length) { %>
        <span class="campo-hint" style="color:var(--warning)">Sin grados registrados. <a href="/grados/nuevo">Crear grado</a></span>
        <% } %>
      </div>

      <div class="campo">
        <label>Sección</label>
        <select name="seccionId" id="selSeccion" onchange="actualizarJornada(this)">
          <% if (seccionesIniciales && seccionesIniciales.length) { %>
          <option value="">Sin sección asignada</option>
          <% seccionesIniciales.forEach(function(s) { %>
          <option value="<%= s._id %>" data-jornada="<%= s.jornada %>"
            <%= alumno.seccion === s.nombre ? 'selected' : '' %>>
            Sección <%= s.nombre %> — <%= s.jornada %>
          </option>
          <% }) %>
          <% } else { %>
          <option value="">Seleccione un grado primero</option>
          <% } %>
        </select>
        <span class="campo-hint">Las secciones se cargan según el grado</span>
      </div>

      <div class="campo">
        <label>Jornada</label>
        <input type="text" id="campoJornada"
               value="<%= alumno.jornada || '' %>"
               disabled class="input-dis" placeholder="Se asigna por la sección">
        <span class="campo-hint">Determinada por la sección seleccionada</span>
      </div>

      <div class="campo">
        <label>Estado</label>
        <select name="estado">
          <option value="activo"    <%= (alumno.estado||'activo')==='activo'   ?'selected':'' %>>Activo</option>
          <option value="inactivo"  <%= alumno.estado==='inactivo' ?'selected':'' %>>Inactivo</option>
          <option value="retirado"  <%= alumno.estado==='retirado' ?'selected':'' %>>Retirado</option>
          <option value="egresado"  <%= alumno.estado==='egresado' ?'selected':'' %>>Egresado</option>
        </select>
      </div>

    </div>
  </div>

  <div class="form-card">
    <div class="form-seccion-titulo">Información de Contacto</div>
    <div class="form-grid">
      <div class="campo">
        <label>Correo Electrónico</label>
        <input type="email" name="correo" value="<%= alumno.correo || '' %>" placeholder="correo@ejemplo.com">
      </div>
      <div class="campo">
        <label>Teléfono</label>
        <input type="text" name="telefono" value="<%= alumno.telefono || '' %>" placeholder="9999-9999">
      </div>
      <div class="campo campo-ancho">
        <label>Dirección</label>
        <input type="text" name="direccion" value="<%= alumno.direccion || '' %>" placeholder="Col./Barrio, Municipio, Departamento">
      </div>
    </div>
  </div>

  <div class="form-card">
    <div class="form-seccion-titulo">Padre / Madre / Tutor Legal</div>
    <div class="form-grid">
      <div class="campo">
        <label>Nombre del tutor</label>
        <input type="text" name="nombreTutor" value="<%= alumno.nombreTutor || '' %>" placeholder="Nombre completo">
      </div>
      <div class="campo">
        <label>Teléfono del tutor</label>
        <input type="text" name="telefonoTutor" value="<%= alumno.telefonoTutor || '' %>" placeholder="9999-9999">
      </div>
    </div>
  </div>

  <div class="form-botones">
    <a href="/alumnos" class="btn btn-secundario">Cancelar</a>
    <button type="submit" class="btn btn-primario">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13"/></svg>
      <%= esEditar ? 'Guardar Cambios' : 'Registrar Alumno' %>
    </button>
  </div>

</form>

<script>
function generarExpediente() {
  fetch('/alumnos/api/proximo-expediente')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var inp = document.getElementById('inputExpediente');
      if (inp && data.expediente) { inp.value = data.expediente; inp.focus(); }
    });
}

function actualizarJornada(sel) {
  var jf  = document.getElementById('campoJornada');
  var opt = sel.options[sel.selectedIndex];
  if (jf) jf.value = (opt && opt.dataset.jornada) ? opt.dataset.jornada : '';
}

function cargarSecciones(gradoId) {
  var sel = document.getElementById('selSeccion');
  var jf  = document.getElementById('campoJornada');
  if (!gradoId) {
    sel.innerHTML = '<option value="">Seleccione un grado primero</option>';
    if (jf) jf.value = '';
    return;
  }
  sel.innerHTML = '<option value="">Cargando...</option>';
  sel.disabled  = true;
  fetch('/alumnos/api/secciones-por-grado/' + gradoId)
    .then(function(r) { return r.json(); })
    .then(function(list) {
      sel.disabled = false;
      if (!list.length) {
        sel.innerHTML = '<option value="">Sin secciones activas en este grado</option>';
        if (jf) jf.value = '';
        return;
      }
      sel.innerHTML = '<option value="">Sin sección asignada</option>' +
        list.map(function(s) {
          return '<option value="' + s._id + '" data-jornada="' + s.jornada + '">' +
            'Sección ' + s.nombre + ' — ' + s.jornada + '</option>';
        }).join('');
      if (jf) jf.value = '';
    })
    .catch(function() {
      sel.disabled  = false;
      sel.innerHTML = '<option value="">Error al cargar secciones</option>';
    });
}

// Generar expediente automáticamente al cargar si está vacío (solo modo nuevo)
window.addEventListener('DOMContentLoaded', function() {
  var inp = document.getElementById('inputExpediente');
  if (inp && !inp.value) generarExpediente();
});
</script>

<%- include('../partials/layout_fin') %>
