<% locals.paginaActual = 'portal-padre' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo">Portal de Padres</h1>
    <p class="page-sub">Bienvenido(a), <%= padre.nombre %> <%= padre.apellido %></p>
  </div>
</div>

<div class="section-label">Mis Hijos / Hijas</div>
<div class="accesos-grid" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));margin-bottom:24px">
  <% hijos.forEach(function(h) { %>
  <a href="/portal-padre/hijo/<%= h.alumno._id %>" class="acceso-card" style="align-items:flex-start;text-align:left;padding:18px">
    <div style="display:flex;align-items:center;gap:10px;width:100%;margin-bottom:8px">
      <div class="detalle-avatar" style="width:40px;height:40px;font-size:13px;background:var(--primary)">
        <%= h.alumno.nombre[0] %><%= h.alumno.apellido[0] %>
      </div>
      <div>
        <div style="font-weight:700;font-size:14px;color:var(--gray-900)"><%= h.alumno.nombre %> <%= h.alumno.apellido %></div>
        <div style="font-size:11.5px;color:var(--gray-400)"><%= h.alumno.expediente %></div>
      </div>
    </div>
    <% if (h.matricula) { %>
    <div style="font-size:12.5px;color:var(--gray-500)">
      <%= h.matricula.seccion.grado.nombre %> — Sección <%= h.matricula.seccion.nombre %>
    </div>
    <% } else { %>
    <div style="font-size:12.5px;color:var(--gray-400)">Sin matrícula activa</div>
    <% } %>
  </a>
  <% }) %>
</div>

<div class="section-label">Accesos Rápidos</div>
<div class="accesos-grid">
  <a href="/mensajeria" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg></div>
    Mensajes
  </a>
</div>

<%- include('../partials/layout_fin') %>
