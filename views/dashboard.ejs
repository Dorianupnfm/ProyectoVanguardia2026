<% locals.paginaActual = 'dashboard' %>
<%- include('partials/layout_inicio') %>
<%- include('partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo">Dashboard</h1>
    <p class="page-sub">Bienvenido, <strong><%= usuarioActual.nombre %></strong> &mdash; Año lectivo <%= anio %></p>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icono si-azul">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
    </div>
    <div><div class="stat-num"><%= totalAlumnos %></div><div class="stat-lbl">Alumnos activos</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-verde">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
    <div><div class="stat-num"><%= totalDocentes %></div><div class="stat-lbl">Docentes activos</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-morado">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
    </div>
    <div><div class="stat-num"><%= totalMatriculas %></div><div class="stat-lbl">Matrículas <%= anio %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-naranja">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
    </div>
    <div><div class="stat-num"><%= totalCarreras %></div><div class="stat-lbl">Carreras activas</div></div>
  </div>
</div>

<div class="section-label">Accesos Rápidos</div>
<div class="accesos-grid">
  <a href="/alumnos/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
    Nuevo Alumno
  </a>
  <a href="/docentes/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
    Nuevo Docente
  </a>
  <a href="/matriculas/nueva" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
    Nueva Matrícula
  </a>
  <% if (usuarioActual && usuarioActual.rol === 'admin') { %>
  <a href="/carreras/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></div>
    Nueva Carrera
  </a>
  <a href="/grados/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg></div>
    Nuevo Grado
  </a>
  <a href="/secciones/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg></div>
    Nueva Sección
  </a>
  <a href="/asignaturas/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg></div>
    Nueva Asignatura
  </a>
  <a href="/usuarios/nuevo" class="acceso-card">
    <div class="acceso-icono"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0112 0v2"/></svg></div>
    Nuevo Usuario
  </a>
  <% } %>
</div>

<%- include('partials/layout_fin') %>
