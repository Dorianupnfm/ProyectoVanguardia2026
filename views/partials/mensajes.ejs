<% if (mensajesExito && mensajesExito.length > 0) { %>
  <% mensajesExito.forEach(function(m) { %>
  <div class="alerta alerta-exito">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
    <%= m %>
  </div>
  <% }) %>
<% } %>
<% if (mensajesError && mensajesError.length > 0) { %>
  <% mensajesError.forEach(function(m) { %>
  <div class="alerta alerta-error">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <%= m %>
  </div>
  <% }) %>
<% } %>
