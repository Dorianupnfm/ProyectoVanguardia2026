<% locals.paginaActual = 'usuarios' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo">Usuarios del Sistema</h1>
    <p class="page-sub"><%= usuarios.length %> usuario(s) registrado(s)</p>
  </div>
  <a href="/usuarios/nuevo" class="btn btn-primario">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nuevo Usuario
  </a>
</div>

<% if (['director','administrativo'].includes(usuarioActual.rol)) { %>
<div style="background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;display:flex;gap:8px;align-items:flex-start">
  <svg viewBox="0 0 24 24" fill="none" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  <span>Puedes <strong>ver la contraseña actual</strong> de cualquier usuario con el botón de candado. Úsalo solo cuando sea estrictamente necesario.</span>
</div>
<% } %>

<div class="tabla-card">
  <table class="tabla">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Correo</th>
        <th>Rol</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
    <% usuarios.forEach(function(u) { %>
    <tr>
      <td><strong><%= u.nombre %></strong></td>
      <td style="font-size:13px"><%= u.email %></td>
      <td>
        <span class="badge badge-<%= u.rol==='director'?'morado':u.rol==='subdirector'?'azul':u.rol==='docente'?'verde':'amarillo' %>">
          <%= ROL_LABELS[u.rol] || u.rol %>
        </span>
      </td>
      <td>
        <% if (u.bloqueadoHasta && new Date() < new Date(u.bloqueadoHasta)) { %>
          <span class="badge badge-rojo">Bloqueado</span>
        <% } else { %>
          <span class="badge badge-<%= u.estado==='activo'?'verde':'rojo' %>"><%= u.estado %></span>
        <% } %>
      </td>
      <td class="acciones">
        <a href="/usuarios/<%= u._id %>/editar" class="btn btn-sm btn-secundario">Editar</a>

        <% if (['director','administrativo'].includes(usuarioActual.rol)) { %>
        <button type="button" class="btn btn-sm btn-ghost"
                onclick="verPassword('<%= u._id %>', '<%= u.nombre.replace(/'/g, "\\'") %>')"
                title="Ver contraseña actual">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" style="width:13px;height:13px"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Ver
        </button>
        <% } %>

        <a href="/usuarios/<%= u._id %>/password" class="btn btn-sm btn-ghost" title="Cambiar contraseña">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" style="width:13px;height:13px"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Cambiar
        </a>
        <% if (u.bloqueadoHasta && new Date() < new Date(u.bloqueadoHasta)) { %>
        <form action="/usuarios/<%= u._id %>/desbloquear" method="POST" style="display:inline">
          <button type="submit" class="btn btn-sm btn-ghost" style="color:var(--success)">Desbloquear</button>
        </form>
        <% } %>
        <% if (u._id.toString() !== usuarioActual.id.toString()) { %>
        <form action="/usuarios/<%= u._id %>/eliminar" method="POST" style="display:inline"
              onsubmit="return confirm('¿Eliminar al usuario <%= u.nombre %>?')">
          <button type="submit" class="btn btn-sm btn-ghost" style="color:var(--danger)">Eliminar</button>
        </form>
        <% } %>
      </td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<!-- Modal de contraseña -->
<% if (['director','administrativo'].includes(usuarioActual.rol)) { %>
<div id="modalPassword" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:1000;align-items:center;justify-content:center" onclick="if(event.target===this)cerrarModal()">
  <div style="background:white;border-radius:12px;padding:28px;max-width:380px;width:90%;box-shadow:0 20px 50px rgba(0,0,0,.3)">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" style="width:20px;height:20px;color:var(--primary)"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      <h3 style="font-size:16px;font-weight:700;color:var(--gray-900)">Contraseña de <span id="modalNombre"></span></h3>
    </div>
    <p style="font-size:12.5px;color:var(--gray-500);margin-bottom:18px">Solo visible para Director y Administrativo del centro.</p>

    <div id="modalContenido" style="background:var(--gray-50);border:1.5px dashed var(--gray-300);border-radius:8px;padding:16px;text-align:center;margin-bottom:18px;min-height:50px;display:flex;align-items:center;justify-content:center">
      <span style="color:var(--gray-400);font-size:13px">Cargando...</span>
    </div>

    <button onclick="cerrarModal()" class="btn btn-secundario btn-block">Cerrar</button>
  </div>
</div>

<script>
function verPassword(id, nombre) {
  document.getElementById('modalNombre').textContent = nombre;
  document.getElementById('modalContenido').innerHTML = '<span style="color:var(--gray-400);font-size:13px">Cargando...</span>';
  document.getElementById('modalPassword').style.display = 'flex';

  fetch('/usuarios/' + id + '/ver-password')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.password) {
        document.getElementById('modalContenido').innerHTML =
          '<code style="font-size:18px;font-weight:700;color:var(--gray-900);letter-spacing:1px">' + data.password + '</code>';
      } else {
        document.getElementById('modalContenido').innerHTML =
          '<span style="color:var(--gray-500);font-size:13px">No disponible. Esta cuenta fue creada antes de habilitar esta función. Usa "Cambiar" para asignar una nueva.</span>';
      }
    })
    .catch(function() {
      document.getElementById('modalContenido').innerHTML =
        '<span style="color:var(--danger);font-size:13px">Error al consultar la contraseña.</span>';
    });
}
function cerrarModal() {
  document.getElementById('modalPassword').style.display = 'none';
}
</script>
<% } %>

<%- include('../partials/layout_fin') %>
