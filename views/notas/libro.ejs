<% locals.paginaActual = 'notas' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<%
var qs = '?asignaturaId=' + asignatura._id + '&seccionId=' + seccion._id + '&parcialId=' + parcial._id;
var NOTA_MINIMA = 60;
%>

<div class="page-header">
  <div>
    <h1 class="page-titulo"><%= asignatura.nombre.toUpperCase() %> — <%= parcial.nombre %></h1>
    <p class="page-sub">
      <%= seccion.grado ? seccion.grado.nombre : '' %> &mdash; Sección <%= seccion.nombre %> &mdash;
      Jornada <span style="text-transform:capitalize"><%= seccion.jornada %></span>
      <% if (asignatura.docente) { %> &mdash; Docente: <strong><%= asignatura.docente.nombre %> <%= asignatura.docente.apellido %></strong><% } %>
    </p>
  </div>
  <a href="/notas" class="btn btn-outline">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Cambiar selección
  </a>
</div>

<!-- Resumen de pesos por componente -->
<div class="pesos-resumen">
  <% COMPONENTES.forEach(function(c) { %>
  <div class="peso-chip">
    <span class="peso-codigo"><%= c %></span>
    <span class="peso-pct"><%= COMPONENTE_PESOS[c] %>%</span>
  </div>
  <% }) %>
  <div class="peso-chip peso-chip-total">
    <span class="peso-codigo">Total</span>
    <span class="peso-pct">100%</span>
  </div>
</div>

<!-- Agregar actividad -->
<div class="form-card" style="margin-bottom:16px">
  <div class="form-seccion-titulo">Nueva Actividad Evaluativa</div>
  <form action="/notas/actividad/nueva" method="POST">
    <input type="hidden" name="asignaturaId" value="<%= asignatura._id %>">
    <input type="hidden" name="seccionId"    value="<%= seccion._id %>">
    <input type="hidden" name="parcialId"    value="<%= parcial._id %>">
    <div class="form-grid">
      <div class="campo">
        <label>Nombre de la actividad <span class="req">*</span></label>
        <input type="text" name="nombre" placeholder="Ej: Prueba 1, Tarea 2..." required>
      </div>
      <div class="campo">
        <label>Componente <span class="req">*</span></label>
        <select name="componente" required>
          <% COMPONENTES.forEach(function(c) { %>
          <option value="<%= c %>"><%= c %> — <%= COMPONENTE_NOMBRES[c] %> (<%= COMPONENTE_PESOS[c] %>% del parcial)</option>
          <% }) %>
        </select>
      </div>
      <div class="campo">
        <label>Puntaje máximo <span class="req">*</span></label>
        <input type="number" name="puntajeMax" value="10" min="1" max="100" required>
      </div>
      <div class="campo">
        <label>Fecha</label>
        <input type="date" name="fecha" value="<%= new Date().toISOString().split('T')[0] %>">
      </div>
    </div>
    <div class="form-botones"><button type="submit" class="btn btn-primario">Agregar Actividad</button></div>
  </form>
</div>

<% if (actividades.length) { %>
<div class="form-card" style="margin-bottom:16px">
  <div class="form-seccion-titulo">Actividades Registradas en este Parcial</div>
  <div style="display:flex;flex-wrap:wrap;gap:8px">
    <% actividades.forEach(function(act) { %>
    <form action="/notas/actividad/<%= act._id %>/eliminar" method="POST"
          onsubmit="return confirm('¿Eliminar la actividad &quot;<%= act.nombre %>&quot;?')">
      <input type="hidden" name="asignaturaId" value="<%= asignatura._id %>">
      <input type="hidden" name="seccionId"    value="<%= seccion._id %>">
      <input type="hidden" name="parcialId"    value="<%= parcial._id %>">
      <button type="submit" class="actividad-chip" title="Eliminar">
        <span class="actividad-chip-comp"><%= act.componente %></span>
        <%= act.nombre %> (/<%= act.puntajeMax %>)
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" style="width:12px;height:12px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </form>
    <% }) %>
  </div>
</div>
<% } %>

<% if (!actividades.length) { %>
<div class="vacio">
  <div class="vacio-ico"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
  <div class="vacio-titulo">Sin actividades para este parcial</div>
  <p>Agrega actividades evaluativas en cada componente para comenzar a registrar notas.</p>
</div>
<% } else { %>

<form action="/notas/guardar" method="POST">
  <input type="hidden" name="asignaturaId" value="<%= asignatura._id %>">
  <input type="hidden" name="seccionId"    value="<%= seccion._id %>">
  <input type="hidden" name="parcialId"    value="<%= parcial._id %>">

  <div class="tabla-card" style="overflow-x:auto;margin-bottom:80px">
    <div class="tabla-card-header">
      <span class="tabla-card-titulo">Calificaciones — <%= matriculas.length %> alumno(s)</span>
    </div>

    <table class="tabla tabla-notas" style="min-width:1000px">
      <thead>
        <!-- Fila 1: nombre de componente agrupado -->
        <tr>
          <th rowspan="2" style="min-width:170px;vertical-align:middle">Alumno</th>
          <% COMPONENTES.forEach(function(comp) { %>
          <% var n = actividadesPorComponente[comp].length; %>
          <th colspan="<%= n > 0 ? n : 1 %>" style="text-align:center;background:#1e293b">
            <%= comp %> <span style="font-weight:400;opacity:.75">(<%= COMPONENTE_PESOS[comp] %>%)</span>
          </th>
          <% }) %>
          <th rowspan="2" style="min-width:90px;text-align:center;vertical-align:middle;background:#0f172a">Nota Final</th>
        </tr>
        <!-- Fila 2: actividades individuales -->
        <tr>
          <% COMPONENTES.forEach(function(comp) { %>
            <% var acts = actividadesPorComponente[comp]; %>
            <% if (acts.length === 0) { %>
            <th style="min-width:70px;text-align:center;font-size:10px;font-weight:400;color:rgba(255,255,255,.5)">Sin actividades</th>
            <% } else { %>
              <% acts.forEach(function(act) { %>
              <th style="min-width:70px;text-align:center">
                <div style="font-size:10.5px;font-weight:600"><%= act.nombre %></div>
                <div style="font-size:9.5px;color:rgba(255,255,255,.6)">/<%= act.puntajeMax %></div>
              </th>
              <% }) %>
            <% } %>
          <% }) %>
        </tr>
      </thead>
      <tbody>
      <% matriculas.forEach(function(m) { %>
      <%
        var aid = m.alumno._id.toString();
        var res = resumen.find(function(r){ return r.alumno._id.toString()===aid; }) || {};
      %>
      <tr>
        <td>
          <div style="font-weight:600;font-size:13px"><%= m.alumno.apellido %>, <%= m.alumno.nombre %></div>
          <div style="font-size:11px;color:var(--gray-400);font-family:var(--font-mono)"><%= m.alumno.expediente %></div>
        </td>

        <% COMPONENTES.forEach(function(comp) { %>
          <% var acts = actividadesPorComponente[comp]; %>
          <% if (acts.length === 0) { %>
          <td style="text-align:center;color:var(--gray-300)">—</td>
          <% } else { %>
            <% acts.forEach(function(act) { %>
            <%
              var nota = notasMap[aid] && notasMap[aid][act._id.toString()];
              var val  = nota ? nota.nota : '';
            %>
            <td style="text-align:center;padding:6px">
              <input type="number" name="nota_<%= aid %>_<%= act._id %>"
                     value="<%= val %>"
                     min="0" max="<%= act.puntajeMax %>"
                     step="0.1"
                     class="input-nota"
                     data-alumno="<%= aid %>"
                     onchange="recalcular('<%= aid %>')">
            </td>
            <% }) %>
          <% } %>
        <% }) %>

        <td style="text-align:center;background:var(--gray-50)" id="nf-<%= aid %>">
          <strong style="font-size:15px;color:<%= res.notaFinal >= NOTA_MINIMA ? 'var(--success)' : 'var(--danger)' %>">
            <%= res.notaFinal %>
          </strong>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Barra guardar fija -->
  <div class="asistencia-guardar">
    <span style="font-size:13px;color:var(--gray-500)"><%= matriculas.length %> alumno(s) — Nota mínima de aprobación: <%= NOTA_MINIMA %></span>
    <button type="submit" class="btn btn-primario" style="padding:11px 28px">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13"/></svg>
      Guardar Notas
    </button>
  </div>
</form>
<% } %>

<style>
.pesos-resumen { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:18px; }
.peso-chip {
  display:flex; flex-direction:column; align-items:center; gap:2px;
  background:white; border:1.5px solid var(--gray-200); border-radius:8px;
  padding:8px 14px; min-width:64px;
}
.peso-codigo { font-size:11px; font-weight:700; color:var(--gray-500); }
.peso-pct    { font-size:16px; font-weight:800; color:var(--primary); }
.peso-chip-total { background:var(--gray-900); border-color:var(--gray-900); }
.peso-chip-total .peso-codigo { color:rgba(255,255,255,.7); }
.peso-chip-total .peso-pct    { color:white; }

.actividad-chip {
  display:inline-flex; align-items:center; gap:6px;
  background:var(--gray-100); border:1.5px solid var(--gray-200);
  border-radius:20px; padding:5px 12px 5px 10px;
  font-size:12px; color:var(--gray-700); cursor:pointer;
  transition:all .12s;
}
.actividad-chip:hover { background:var(--danger-cl); border-color:var(--danger); color:var(--danger); }
.actividad-chip-comp {
  background:var(--primary); color:white; font-weight:700;
  font-size:10px; padding:2px 6px; border-radius:10px;
}
.actividad-chip:hover .actividad-chip-comp { background:var(--danger); }

.tabla-notas thead tr:first-child th { background:#1e293b; color:white; font-size:12px; padding:8px 6px; }
.tabla-notas thead tr:nth-child(2) th { background:#334155; color:white; padding:6px; }

.input-nota {
  width:58px; text-align:center; padding:5px;
  border:1.5px solid var(--gray-300); border-radius:6px; font-size:13px;
}
.input-nota:focus { outline:none; border-color:var(--primary); box-shadow:0 0 0 2px rgba(26,86,219,.12); }

.asistencia-guardar {
  position:fixed; bottom:0; left:var(--sb-w); right:0;
  background:white; border-top:1px solid var(--gray-200);
  padding:14px 28px; display:flex; align-items:center; justify-content:space-between;
  z-index:100; box-shadow:0 -4px 16px rgba(0,0,0,.08);
}
@media (max-width:1024px) { .asistencia-guardar { left:0; } }
</style>

<script>
// Pesos y máximos por componente, precargados desde el servidor
var PESOS = {
  <% COMPONENTES.forEach(function(c) { %>'<%= c %>': <%= COMPONENTE_PESOS[c] %>,<% }) %>
};
var ACT_POR_COMPONENTE = {
  <% COMPONENTES.forEach(function(c) { %>
  '<%= c %>': [<% actividadesPorComponente[c].forEach(function(a,i) { %>{id:'<%= a._id %>',max:<%= a.puntajeMax %>}<%= i<actividadesPorComponente[c].length-1?',':'' %><% }) %>],
  <% }) %>
};

function recalcular(alumnoId) {
  var notaFinal = 0;
  Object.keys(ACT_POR_COMPONENTE).forEach(function(comp) {
    var acts = ACT_POR_COMPONENTE[comp];
    var obtenido = 0, maximo = 0;
    acts.forEach(function(a) {
      var inp = document.querySelector('[name="nota_' + alumnoId + '_' + a.id + '"]');
      maximo += a.max;
      if (inp && inp.value !== '') {
        var v = parseFloat(inp.value);
        if (v > a.max) { inp.value = a.max; v = a.max; }
        if (v < 0)     { inp.value = 0;     v = 0; }
        obtenido += v;
      }
    });
    var peso = PESOS[comp];
    var aporte = maximo > 0 ? (obtenido / maximo) * peso : 0;
    notaFinal += aporte;
  });
  notaFinal = Math.round(notaFinal * 10) / 10;

  var celda = document.getElementById('nf-' + alumnoId);
  if (celda) {
    var color = notaFinal >= 60 ? 'var(--success)' : 'var(--danger)';
    celda.innerHTML = '<strong style="font-size:15px;color:' + color + '">' + notaFinal + '</strong>';
  }
}
</script>

<%- include('../partials/layout_fin') %>
