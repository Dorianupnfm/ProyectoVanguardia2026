<% locals.paginaActual = 'asignaturas' %>
<%- include('../partials/layout_inicio') %><%- include('../partials/mensajes') %>
<div class="page-header"><h1 class="page-titulo"><%= titulo %></h1><a href="/asignaturas" class="btn btn-outline">← Volver</a></div>
<% var accion = esEditar ? '/asignaturas/' + asignatura._id : '/asignaturas' %>
<form action="<%= accion %>" method="POST">
  <div class="form-card">
    <div class="form-seccion-titulo">Datos de la Asignatura</div>
    <div class="form-grid">
      <div class="campo"><label>Nombre *</label><input type="text" name="nombre" value="<%= asignatura.nombre||'' %>" placeholder="Ej: Matemáticas" required></div>
      <div class="campo"><label>Código</label><input type="text" name="codigo" value="<%= asignatura.codigo||'' %>" placeholder="MAT"></div>
      <div class="campo"><label>Grado *</label>
        <select name="grado" required>
          <option value="">Seleccionar grado</option>
          <% grados.forEach(g => { %>
          <option value="<%= g._id %>" <%= asignatura.grado?._id?.toString()===g._id.toString()?'selected':'' %>><%= g.nombre %> (<%= g.anioEscolar %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="campo"><label>Docente Asignado</label>
        <select name="docente">
          <option value="">Sin docente asignado</option>
          <% docentes.forEach(d => { %>
          <option value="<%= d._id %>" <%= asignatura.docente?._id?.toString()===d._id.toString()?'selected':'' %>><%= d.apellido %>, <%= d.nombre %></option>
          <% }) %>
        </select>
      </div>
      <div class="campo"><label>Horas por semana</label><input type="number" name="horasSemana" value="<%= asignatura.horasSemana||4 %>" min="1" max="20"></div>
      <div class="campo"><label>Estado</label>
        <select name="estado">
          <option value="activa" <%= (asignatura.estado||'activa')==='activa'?'selected':'' %>>Activa</option>
          <option value="inactiva" <%= asignatura.estado==='inactiva'?'selected':'' %>>Inactiva</option>
        </select>
      </div>
    </div>
  </div>
  <div class="form-botones"><a href="/asignaturas" class="btn btn-outline">Cancelar</a><button type="submit" class="btn btn-primario"><%= esEditar?'Guardar':'Registrar' %></button></div>
</form>
<%- include('../partials/layout_fin') %>
