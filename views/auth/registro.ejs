<%# views/auth/registro.ejs — formulario de registro %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Crear Cuenta — SoftWork</title>
  <link rel="stylesheet" href="/css/estilo.css">
</head>
<body class="body-auth">

<div class="auth-container">
  <div class="auth-card">

    <div class="auth-header">
      <div class="auth-icono"></div>
      <h1 class="auth-titulo">Crear Cuenta</h1>
      <p class="auth-subtitulo">Completa los datos para registrarte</p>
    </div>

    <% if (mensajesError && mensajesError.length > 0) { %>
      <% mensajesError.forEach(msg => { %>
        <div class="alerta alerta-error"><%= msg %></div>
      <% }) %>
    <% } %>

    <form action="/auth/registro" method="POST" class="form">

      <div class="campo">
        <label for="nombre">Nombre completo</label>
        <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" required>
      </div>

      <div class="campo">
        <label for="email">Correo Electrónico</label>
        <input type="email" id="email" name="email" placeholder="correo@ejemplo.com" required>
      </div>

      <div class="campo">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" placeholder="Mínimo 6 caracteres" required>
      </div>

      <div class="campo">
        <label for="rol">Rol</label>
        <select id="rol" name="rol">
          <option value="secretario">Secretario</option>
          <option value="docente">Docente</option>
          <option value="admin">Administrador</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primario btn-block">Crear Cuenta</button>

    </form>

    <div class="auth-pie">
      ¿Ya tienes cuenta? <a href="/auth/login">Iniciar sesión</a>
    </div>

  </div>
</div>

</body>
</html>
