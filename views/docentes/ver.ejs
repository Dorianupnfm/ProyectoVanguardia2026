<% locals.paginaActual = 'docentes' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo">Ficha del Docente</h1>
    <p class="page-sub"><%= docente.especialidad||'Docente del centro' %></p>
  </div>
  <div class="page-acciones">
    <a href="/docentes/<%= docente._id %>/editar" class="btn btn-primario">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Editar
    </a>
    <a href="/docentes" class="btn btn-secundario">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Volver
    </a>
  </div>
</div>

<div class="detalle-card">
  <div class="detalle-header" style="background:linear-gradient(135deg,#064e3b,#047857)">
    <div class="detalle-avatar" style="background:#059669"><%= docente.nombre[0] %><%= docente.apellido[0] %></div>
    <div>
      <h2 class="detalle-nombre"><%= docente.apellido %>, <%= docente.nombre %></h2>
      <div class="detalle-sub">
        <%= docente.titulo||'Sin título registrado' %>
        &nbsp;&nbsp;
        <span class="badge badge-<%= docente.estado==='activo'?'verde':'rojo' %>"><%= docente.estado %></span>
      </div>
    </div>
  </div>

  <div class="detalle-grid">
    <div class="detalle-sec">
      <h3>Datos Personales</h3>
      <div class="dato-fila"><span>N. Identidad</span><strong><%= docente.numIdentidad||'—' %></strong></div>
      <div class="dato-fila"><span>Fecha de Ingreso</span><strong><%= docente.fechaIngreso ? docente.fechaIngreso.toLocaleDateString('es-HN') : '—' %></strong></div>
      <div class="dato-fila"><span>Especialidad</span><strong><%= docente.especialidad||'—' %></strong></div>
      <div class="dato-fila"><span>Título</span><strong><%= docente.titulo||'—' %></strong></div>
    </div>

    <div class="detalle-sec">
      <h3>Contacto</h3>
      <div class="dato-fila"><span>Correo</span><strong><%= docente.correo||'—' %></strong></div>
      <div class="dato-fila"><span>Teléfono</span><strong><%= docente.telefono||'—' %></strong></div>
    </div>

    <% if (asignaturas && asignaturas.length) { %>
    <div class="detalle-sec">
      <h3>Asignaturas que Imparte</h3>
      <% asignaturas.forEach(function(a) { %>
      <div class="dato-fila">
        <span><%= a.nombre %></span>
        <strong><%= a.grado ? a.grado.nombre : '—' %></strong>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (secciones && secciones.length) { %>
    <div class="detalle-sec">
      <h3>Secciones a Cargo</h3>
      <% secciones.forEach(function(s) { %>
      <div class="dato-fila">
        <span>Sección <%= s.nombre %></span>
        <strong><%= s.grado ? s.grado.nombre : '—' %></strong>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="detalle-footer">
    <form action="/docentes/<%= docente._id %>/eliminar" method="POST"
          onsubmit="return confirm('Esta acción no se puede deshacer. ¿Eliminar docente?')">
      <button type="submit" class="btn btn-peligro">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
        Eliminar Docente
      </button>
    </form>
  </div>
</div>

<%- include('../partials/layout_fin') %>
