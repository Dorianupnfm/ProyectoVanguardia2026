<% locals.paginaActual = 'grados' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo"><%= grado.nombre %></h1>
    <p class="page-sub">
      <% if (grado.nivel === 'ciclo-basico') { %>
        Ciclo Básico &mdash; Plan común &mdash; Año <%= grado.anioEscolar %>
      <% } else { %>
        Bachillerato
        <% if (grado.carrera) { %>&mdash; <%= grado.carrera.nombre %><% } %>
        &mdash; Año <%= grado.anioEscolar %>
      <% } %>
    </p>
  </div>
  <div class="page-acciones">
    <a href="/grados/<%= grado._id %>/editar" class="btn btn-secundario">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Editar
    </a>
    <a href="/grados" class="btn btn-outline">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Volver
    </a>
  </div>
</div>

<!-- Chips de nivel y carrera -->
<div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:22px">
  <% if (grado.nivel === 'ciclo-basico') { %>
  <span class="nivel-chip nivel-chip-basico">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
    Ciclo Básico
  </span>
  <% } else { %>
  <span class="nivel-chip nivel-chip-bach">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
    Bachillerato
  </span>
  <% if (grado.carrera) { %>
  <span class="nivel-chip" style="background:var(--purple-cl);color:var(--purple);border:1px solid #c4b5fd">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
    <%= grado.carrera.nombre %>
    <% if (grado.carrera.codigo) { %>(<%= grado.carrera.codigo %>)<% } %>
  </span>
  <% } %>
  <% } %>
  <span class="badge badge-<%= grado.estado==='activo'?'verde':'rojo' %>" style="padding:6px 12px">
    <%= grado.estado %>
  </span>
</div>

<!-- Stats rápidas -->
<div class="stats-grid" style="margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-icono si-azul">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div><div class="stat-num"><%= matriculas.length %></div><div class="stat-lbl">Alumnos matriculados</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-verde">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
    </div>
    <div><div class="stat-num"><%= secciones.length %></div><div class="stat-lbl">Secciones</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-morado">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
    </div>
    <div><div class="stat-num"><%= asignaturas.length %></div><div class="stat-lbl">Asignaturas</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-naranja">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
    <div><div class="stat-num"><%= docentes.length %></div><div class="stat-lbl">Docentes asignados</div></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">

  <!-- Secciones -->
  <div class="tabla-card">
    <div class="tabla-card-header">
      <span class="tabla-card-titulo">Secciones</span>
      <a href="/secciones/nuevo" class="btn btn-sm btn-primario">+ Nueva</a>
    </div>
    <% if (!secciones.length) { %>
    <div style="padding:20px;text-align:center;color:var(--gray-400);font-size:13px">Sin secciones</div>
    <% } else { %>
    <table class="tabla">
      <thead><tr><th>Sección</th><th>Jornada</th><th>Docente Tutor</th><th>Cap.</th></tr></thead>
      <tbody>
      <% secciones.forEach(function(s) { %>
      <tr>
        <td><strong>Sección <%= s.nombre %></strong></td>
        <td><span class="badge badge-azul" style="text-transform:capitalize"><%= s.jornada %></span></td>
        <td style="font-size:12.5px"><%= s.docente ? s.docente.apellido+', '+s.docente.nombre : '—' %></td>
        <td><%= s.capacidad %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- Docentes -->
  <div class="tabla-card">
    <div class="tabla-card-header">
      <span class="tabla-card-titulo">Docentes que imparten clases</span>
    </div>
    <% if (!docentes.length) { %>
    <div style="padding:20px;text-align:center;color:var(--gray-400);font-size:13px">Sin docentes asignados</div>
    <% } else { %>
    <table class="tabla">
      <thead><tr><th>Docente</th><th>Especialidad</th></tr></thead>
      <tbody>
      <% docentes.forEach(function(d) { %>
      <tr>
        <td><strong><%= d.apellido %>, <%= d.nombre %></strong></td>
        <td style="font-size:12.5px;color:var(--gray-500)"><%= d.especialidad||'—' %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

</div>

<!-- Asignaturas -->
<div class="tabla-card" style="margin-bottom:20px">
  <div class="tabla-card-header">
    <span class="tabla-card-titulo">Asignaturas del Grado</span>
    <a href="/asignaturas/nuevo" class="btn btn-sm btn-primario">+ Nueva</a>
  </div>
  <% if (!asignaturas.length) { %>
  <div style="padding:20px;text-align:center;color:var(--gray-400);font-size:13px">Sin asignaturas registradas</div>
  <% } else { %>
  <table class="tabla">
    <thead><tr><th>Asignatura</th><th>Código</th><th>Docente</th><th>Hrs/Sem</th><th>Estado</th></tr></thead>
    <tbody>
    <% asignaturas.forEach(function(a) { %>
    <tr>
      <td><strong><%= a.nombre %></strong></td>
      <td><code><%= a.codigo||'—' %></code></td>
      <td style="font-size:12.5px"><%= a.docente ? a.docente.apellido+', '+a.docente.nombre : '—' %></td>
      <td><%= a.horasSemana %> hrs</td>
      <td><span class="badge badge-<%= a.estado==='activa'?'verde':'rojo' %>"><%= a.estado %></span></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- Alumnos matriculados -->
<div class="tabla-card">
  <div class="tabla-card-header">
    <span class="tabla-card-titulo">Alumnos Matriculados</span>
    <span class="badge badge-azul"><%= matriculas.length %> alumnos</span>
  </div>
  <% if (!matriculas.length) { %>
  <div style="padding:20px;text-align:center;color:var(--gray-400);font-size:13px">Sin alumnos matriculados en este grado</div>
  <% } else { %>
  <table class="tabla">
    <thead><tr><th>Expediente</th><th>Nombre</th><th>Sección</th><th>Jornada</th></tr></thead>
    <tbody>
    <% matriculas.forEach(function(m) { %>
    <tr>
      <td><code><%= m.alumno.expediente %></code></td>
      <td><strong><%= m.alumno.apellido %>, <%= m.alumno.nombre %></strong></td>
      <td><span class="badge badge-azul">Sec. <%= m.seccion ? m.seccion.nombre : '—' %></span></td>
      <td style="text-transform:capitalize;font-size:12.5px"><%= m.seccion?.jornada||'—' %></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<style>
.nivel-chip {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 7px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;
}
.nivel-chip svg { width: 14px; height: 14px; stroke: currentColor; }
.nivel-chip-basico { background: var(--primary-bg); color: var(--primary-d); border: 1px solid var(--primary-cl); }
.nivel-chip-bach   { background: var(--purple-cl);  color: var(--purple);    border: 1px solid #c4b5fd; }
</style>

<%- include('../partials/layout_fin') %>
