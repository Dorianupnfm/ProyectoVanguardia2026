<% locals.paginaActual = 'asistencia-nueva' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div><h1 class="page-titulo">Pasar Asistencia</h1><p class="page-sub">Selecciona asignatura, sección y fecha</p></div>
</div>

<div class="form-card" style="max-width:560px">
  <div class="form-seccion-titulo">Configurar Sesión</div>
  <form action="/asistencia/lista" method="GET" id="frmSeleccionar">
    <div class="form-grid">

      <div class="campo campo-ancho">
        <label>Asignatura <span class="req">*</span></label>
        <select name="asignaturaId" id="selAsig" required onchange="cargarSecciones(this.value)">
          <option value="">Seleccionar asignatura...</option>
          <% asignaturas.forEach(function(a) { %>
          <option value="<%= a._id %>" <%= asignaturaId===a._id.toString()?'selected':'' %>>
            <%= a.nombre %> — <%= a.grado ? a.grado.nombre : '' %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="campo">
        <label>Sección <span class="req">*</span></label>
        <select name="seccionId" id="selSeccion" required>
          <option value="">Seleccionar sección...</option>
          <% secciones.forEach(function(s) { %>
          <option value="<%= s._id %>">Sección <%= s.nombre %></option>
          <% }) %>
        </select>
      </div>

      <div class="campo">
        <label>Fecha <span class="req">*</span></label>
        <input type="date" name="fecha" value="<%= hoy %>" required>
      </div>

    </div>
    <div class="form-botones">
      <a href="/docente" class="btn btn-secundario">Cancelar</a>
      <button type="submit" class="btn btn-primario">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        Continuar
      </button>
    </div>
  </form>
</div>

<script>
function cargarSecciones(asigId) {
  var sel = document.getElementById('selSeccion');
  if (!asigId) { sel.innerHTML = '<option value="">Seleccionar sección...</option>'; return; }
  sel.innerHTML = '<option value="">Cargando...</option>';
  fetch('/asistencia/api/secciones/' + asigId)
    .then(function(r) { return r.json(); })
    .then(function(list) {
      sel.innerHTML = '<option value="">Seleccionar sección...</option>' +
        list.map(function(s) {
          return '<option value="' + s._id + '">Sección ' + s.nombre + '</option>';
        }).join('');
    });
}
// Si viene preseleccionada una asignatura, cargar sus secciones
window.addEventListener('DOMContentLoaded', function() {
  var sel = document.getElementById('selAsig');
  if (sel.value) cargarSecciones(sel.value);
});
</script>
<%- include('../partials/layout_fin') %>
