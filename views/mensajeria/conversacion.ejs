<% locals.paginaActual = 'mensajeria' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<%
  var otro = conv.participantes.find(function(p){ return p._id.toString() !== usuarioActual.id.toString(); });
%>

<div class="page-header">
  <div>
    <h1 class="page-titulo"><%= otro ? otro.nombre : 'Conversación' %></h1>
    <p class="page-sub">
      <%= ROL_LABELS[otro ? otro.rol : ''] || '' %>
      <% if (conv.alumnoRelacionado) { %> &mdash; Sobre: <%= conv.alumnoRelacionado.nombre %> <%= conv.alumnoRelacionado.apellido %><% } %>
    </p>
  </div>
  <a href="/mensajeria" class="btn btn-outline">Volver</a>
</div>

<div class="chat-card">
  <div class="chat-mensajes" id="chatMensajes">
    <% mensajes.forEach(function(m) { %>
    <%
      var esMio = m.emisor._id.toString() === usuarioActual.id.toString();
    %>
    <div class="chat-fila <%= esMio ? 'chat-fila-mia' : '' %>">
      <div class="chat-burbuja <%= esMio ? 'chat-burbuja-mia' : '' %>">
      <% if (!esMio) { %><div class="chat-emisor"><%= m.emisor.nombre %></div><% } %>
        <% if (m.contenido) { %><div class="chat-texto"><%= m.contenido %></div><% } %>
        <% if (m.adjunto && m.adjunto.ruta) { %>
        <div class="chat-adjunto" style="margin-top:<%= m.contenido ? '6px' : '0' %>">
          <% if (m.adjunto.esImagen) { %>
          <a href="<%= m.adjunto.ruta %>" target="_blank">
            <img src="<%= m.adjunto.ruta %>" alt="<%= m.adjunto.nombre %>"
                 style="max-width:220px;max-height:180px;border-radius:8px;display:block">
          </a>
          <% } else { %>
          <a href="<%= m.adjunto.ruta %>" target="_blank" download="<%= m.adjunto.nombre %>"
             style="display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:6px;padding:6px 10px;font-size:12.5px;color:inherit;text-decoration:none">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" style="width:14px;height:14px"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <%= m.adjunto.nombre %>
          </a>
          <% } %>
        </div>
        <% } %>
        <div class="chat-hora"><%= new Date(m.createdAt).toLocaleString('es-HN', {hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit'}) %></div>
      </div>
    </div>
    <% }) %>
    <% if (!mensajes.length) { %>
    <div style="text-align:center;color:var(--gray-400);font-size:13px;padding:30px">Inicia la conversación</div>
    <% } %>
  </div>

  <form action="/mensajeria/<%= conv._id %>/enviar" method="POST" class="chat-form" enctype="multipart/form-data" id="formEnviar">
    <label for="adjuntoResp" class="btn btn-ghost" style="padding:8px;margin:0;cursor:pointer" title="Adjuntar archivo">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" style="width:18px;height:18px"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
    </label>
    <input type="file" name="adjunto" id="adjuntoResp" style="display:none"
           accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.txt"
           onchange="previsualizarAdjunto(this)">
    <div style="flex:1;display:flex;flex-direction:column;gap:4px">
      <input type="text" name="contenido" id="inputMensaje" placeholder="Escribe tu mensaje..." autocomplete="off" class="chat-input">
      <div id="prevAdjuntoResp" style="display:none;font-size:12px;color:var(--primary);padding:2px 6px"></div>
    </div>
    <button type="submit" class="btn btn-primario" style="padding:10px 16px">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </form>
</div>

<style>
.chat-card {
  background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm); display: flex; flex-direction: column;
  height: calc(100vh - 220px); min-height: 400px;
}
.chat-mensajes { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 10px; }
.chat-fila { display: flex; }
.chat-fila-mia { justify-content: flex-end; }
.chat-burbuja {
  max-width: 65%; background: var(--gray-100); border-radius: 14px 14px 14px 4px;
  padding: 10px 14px;
}
.chat-burbuja-mia { background: var(--primary); color: white; border-radius: 14px 14px 4px 14px; }
.chat-emisor { font-size: 11px; font-weight: 700; color: var(--primary); margin-bottom: 2px; }
.chat-texto { font-size: 14px; line-height: 1.4; }
.chat-hora { font-size: 10px; opacity: .6; margin-top: 4px; text-align: right; }
.chat-form { display: flex; gap: 10px; padding: 14px 20px; border-top: 1px solid var(--gray-200); }
.chat-input {
  flex: 1; padding: 10px 14px; border: 1.5px solid var(--gray-300); border-radius: 24px; font-size: 14px;
}
.chat-input:focus { outline: none; border-color: var(--primary); }
</style>

<script>
var box = document.getElementById('chatMensajes');
if (box) box.scrollTop = box.scrollHeight;

function previsualizarAdjunto(input) {
  var prev = document.getElementById('prevAdjuntoResp');
  var file = input.files[0];
  if (!file) { prev.style.display = 'none'; return; }
  if (file.size > 5 * 1024 * 1024) {
    alert('El archivo excede 5 MB.');
    input.value = ''; prev.style.display = 'none'; return;
  }
  prev.style.display = 'block';
  prev.innerHTML = '📎 ' + file.name + ' (' + (file.size/1024).toFixed(0) + ' KB) <span onclick="quitarAdjunto()" style="cursor:pointer;color:var(--danger)">✕</span>';
}

function quitarAdjunto() {
  document.getElementById('adjuntoResp').value = '';
  document.getElementById('prevAdjuntoResp').style.display = 'none';
}
</script>

<%- include('../partials/layout_fin') %>
