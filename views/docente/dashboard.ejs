<% locals.paginaActual = 'docente-dashboard' %>
<%- include('../partials/layout_inicio') %>
<%- include('../partials/mensajes') %>

<div class="page-header">
  <div>
    <h1 class="page-titulo">Bienvenido, <%= docente.nombre %></h1>
    <p class="page-sub">Portal Docente — <%= new Date().toLocaleDateString('es-HN', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></p>
  </div>
  <a href="/asistencia/nueva" class="btn btn-primario">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
    Pasar Asistencia
  </a>
</div>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icono si-azul">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
    </div>
    <div><div class="stat-num"><%= asignaturas.length %></div><div class="stat-lbl">Asignaturas asignadas</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-verde">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
    </div>
    <div><div class="stat-num"><%= secciones.length %></div><div class="stat-lbl">Secciones a cargo</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-morado">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div><div class="stat-num"><%= totalAlumnos %></div><div class="stat-lbl">Alumnos en mis secciones</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icono si-naranja">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
    </div>
    <div><div class="stat-num"><%= ultimasAsistencias.length %></div><div class="stat-lbl">Asistencias recientes</div></div>
  </div>
</div>

<!-- Mis asignaturas -->
<div class="section-label">Mis Asignaturas</div>
<div class="accesos-grid" style="margin-bottom:24px">
  <% asignaturas.forEach(function(a) { %>
  <a href="/asistencia/nueva?asignatura=<%= a._id %>" class="acceso-card">
    <div class="acceso-icono">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>
    </div>
    <div style="font-weight:700"><%= a.nombre %></div>
    <div style="font-size:11px;color:var(--gray-400)"><%= a.grado ? a.grado.nombre : '' %></div>
  </a>
  <% }) %>
</div>

<!-- Últimas asistencias -->
<% if (ultimasAsistencias.length) { %>
<div class="section-label">Últimas Sesiones Registradas</div>
<div class="tabla-card">
  <table class="tabla">
    <thead><tr><th>Fecha</th><th>Asignatura</th><th>Sección</th><th>Acciones</th></tr></thead>
    <tbody>
    <% ultimasAsistencias.forEach(function(r) { %>
    <tr>
      <td><%= new Date(r.fecha).toLocaleDateString('es-HN') %></td>
      <td><strong><%= r.asignatura ? r.asignatura.nombre : '—' %></strong></td>
      <td>Sección <%= r.seccion ? r.seccion.nombre : '—' %></td>
      <td><a href="/asistencia/ver/<%= r._id %>" class="btn btn-sm btn-outline">Ver</a></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('../partials/layout_fin') %>
